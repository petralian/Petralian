direction: down
vars: { d2-config: { sketch: false } }

grid: {
  grid.columns: 1
  direction: down

  L1: "Layer 1 — Short term" {
    direction: down
    style.fill: "#fff8f5"
    style.stroke: "#ff6a3d"
    style.font-size: 14
    CHAT: "Agent chat + todos"
    LIVE: "Live workspace / git state"
  }
  L2: "Layer 2 — Operational" {
    direction: down
    style.fill: "#f5f7fa"
    style.stroke: "#d8dce6"
    style.font-size: 14
    SNAP: "last-session-bootstrap snapshot"
    HAND: ".claude/NEXT_SESSION.md"
    MEM: "memories/repo/open-loops.md"
    OPS: "Obsidian Operations/*"
  }
  L3: "Layer 3 — Evergreen" {
    direction: down
    style.fill: "#f5f7fa"
    style.stroke: "#d8dce6"
    style.font-size: 14
    FEAT: "Features/*.md"
    ARCH: "Architecture/*.md"
    BRAIN: "00_Brain/Conventions/*"
  }
  L4: "Layer 4 — Feedback hardened" {
    direction: down
    style.fill: "#f5f7fa"
    style.stroke: "#d8dce6"
    style.font-size: 14
    RULES: "Agent instructions + rules"
    AGENTS: "Custom agents + skills"
    HOOKS: "Git + IDE session hooks"
  }
}

grid.L1 -> grid.L2: "session end protocol" { style.stroke: "#ff6a3d" }
grid.L2 -> grid.L3: "promote durable facts" { style.stroke: "#ff6a3d" }
grid.L1 -> grid.L4: "lessons → rules" { style.stroke: "#ff6a3d" }
grid.L4 -> grid.L1: "feedback" { style.stroke: "#696d84"; style.stroke-dash: 8 }
grid.L3 -> grid.L1: "feedback" { style.stroke: "#696d84"; style.stroke-dash: 8 }
