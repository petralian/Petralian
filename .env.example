# Newsletter provider: brevo, kit, or buttondown
NEWSLETTER_PROVIDER=brevo

# Brevo settings (recommended)
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Petralian
BREVO_DAILY_LIMIT=300

# Security for cron + unsubscribe links
CRON_SECRET=
UNSUBSCRIBE_SECRET=
NEWSLETTER_DEBUG=0

# Kit (ConvertKit) settings
KIT_FORM_ID=
KIT_API_KEY=

# Buttondown settings (optional alternative)
BUTTONDOWN_API_KEY=
