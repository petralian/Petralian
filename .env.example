# Newsletter provider: brevo, kit, or buttondown
NEWSLETTER_PROVIDER=brevo

# Brevo settings (recommended)
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Petralian
BREVO_DAILY_LIMIT=300

# Security for cron + unsubscribe links
CRON_SECRET=
UNSUBSCRIBE_SECRET=
SUBSCRIBE_CONFIRM_SECRET=
NEWSLETTER_DEBUG=0

# Orbit Rush global leaderboard (Upstash Redis via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV names also supported:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Kit (ConvertKit) settings
KIT_FORM_ID=
KIT_API_KEY=

# Buttondown settings (optional alternative)
BUTTONDOWN_API_KEY=
