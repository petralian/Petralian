{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 92",
    "firefox >= 90",
    "safari >= 15.4",
    "edge >= 92",
    "not dead"
  ],
  "scripts": {
    "dev": "tinacms dev -c \"next dev -H 0.0.0.0\"",
    "dev:local": "next dev -H 0.0.0.0",
    "build": "node scripts/generate-llms-txt.mjs && tinacms build --skip-cloud-checks && cross-env NODE_OPTIONS=--max-old-space-size=1024 next build",
    "start": "next start",
    "optimize-images": "node scripts/optimize-images.mjs",
    "optimize-images:dry": "node scripts/optimize-images.mjs --dry-run",
    "diagram-compare": "node scripts/render-diagram-compare.mjs",
    "generate:llms-txt": "node scripts/generate-llms-txt.mjs",
    "post-publish:seo": "node scripts/post-publish-seo.mjs",
    "request-indexing": "node scripts/request-indexing.mjs",
    "autofix:seo": "node scripts/autofix-seo-meta.mjs",
    "autofix:seo:dry": "node scripts/autofix-seo-meta.mjs --dry-run",
    "audit:pre-publish": "node scripts/audit-pre-publish.mjs",
    "audit:lighthouse": "node scripts/audit-lighthouse.mjs",
    "generate:disavow": "node scripts/generate-disavow.mjs",
    "audit:cloudflare-dns": "node scripts/audit-cloudflare-dns.mjs",
    "audit:internal-links": "node scripts/audit-internal-links.mjs",
    "audit:seo-meta": "node scripts/audit-seo-meta.mjs",
    "audit:live-sitemap": "node scripts/audit-live-sitemap.mjs",
    "audit:wp-redirects": "node scripts/audit-wp-redirects.mjs",
    "audit:crm-noindex": "node scripts/audit-crm-noindex.mjs",
    "audit:site": "node scripts/audit-internal-links.mjs && node scripts/audit-live-sitemap.mjs && node scripts/audit-seo-meta.mjs"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/redis": "^1.38.0",
    "date-fns": "^4.3.0",
    "gray-matter": "^4.0.3",
    "howler": "^2.2.4",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-zoom-pan-pinch": "^4.0.3",
    "reading-time": "^1.5.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tinacms": "^2.10.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tinacms/cli": "^2.3.1",
    "@types/howler": "^2.2.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "image-size": "^2.0.2",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
